# =============================================================
# Twitter AI System — Environment Variables Template
# Salin file ini ke .env dan isi nilainya.
# JANGAN pernah commit file .env ke git!
# =============================================================

# -----------------------------------------------------------
# LLM (OpenAI-compatible API — provider-agnostic)
# Didukung: LLM_* (direkomendasikan) atau OPENAI_* (legacy)
# -----------------------------------------------------------
LLM_BASE_URL=https://your-provider-base-url/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=your-model-name

# Nama lama (masih didukung sebagai fallback):
# OPENAI_BASE_URL=https://your-provider-base-url/v1
# OPENAI_API_KEY=your-api-key-here
# AI_MODEL=your-model-name

# -----------------------------------------------------------
# Telegram
# -----------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# -----------------------------------------------------------
# X (Twitter) — OPSIONAL
# Tidak dipakai untuk auto-post. Hanya untuk referensi arsip.
# -----------------------------------------------------------
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# -----------------------------------------------------------
# Opsional
# -----------------------------------------------------------
# POST_INTERVAL_HOURS=1   # fallback interval scheduler lama
